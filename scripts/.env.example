# Public HTTPS URL only — not a secret
FEED_URL=https://raw.githubusercontent.com/<OWNER>/<REPO>/main/feed-investor.json

# Maintainer only — never commit real tokens (GitHub Actions: TWITTER_BEARER_TOKEN and/or X_BEARER_TOKEN)
# TWITTER_BEARER_TOKEN=
# X_BEARER_TOKEN=

# Optional Reddit script app (client_credentials) if public JSON/RSS still 403 from CI — readers still need no key
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
