{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pevc-ai-radar.local/feed-investor.schema.json",
  "title": "PEVC AI Radar feed",
  "type": "object",
  "required": ["version", "updatedAt", "items"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "updatedAt": { "type": "string", "format": "date-time" },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "title", "url", "source", "publishedAt"],
        "properties": {
          "id": { "type": "string" },
          "type": {
            "type": "string",
            "enum": [
              "funding",
              "news",
              "social_en",
              "social_cn",
              "oss",
              "paper",
              "crowdfunding"
            ]
          },
          "title": { "type": "string" },
          "url": { "type": "string", "format": "uri" },
          "source": { "type": "string" },
          "publishedAt": { "type": "string" },
          "summaryHint": { "type": "string" },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
